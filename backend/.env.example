# Async PostgreSQL (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/goldpulse

# Quote worker
QUOTE_POLL_INTERVAL_SEC=3
SIMULATED_XAUUSD_MID=2650.00
QUOTE_BINANCE_SYMBOL=PAXGUSDT

