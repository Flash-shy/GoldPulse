{
  "name": "goldpulse",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "dev:mobile": "npm run start -w mobile",
    "dev:api": "cd backend && .venv/bin/uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "stats": "bash stats.sh",
    "compose:up": "docker compose up --build",
    "compose:build": "docker compose build"
  }
}
